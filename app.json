{
  "expo": {
    "name": "Blockerino",
    "slug": "blockerino",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050510"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nerdlin.blockerino",
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "package": "com.nerdlin.blockerino",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050510"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "runtimeVersion": "1.0.2"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050510"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/PressStart2P-Regular.ttf"
          ]
        }
      ],
      "expo-audio",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/blockerino"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca108ad1-37de-4a05-868d-31ba91e722a7"
      }
    },
    "owner": "nerdlin",
    "updates": {
      "url": "https://u.expo.dev/ca108ad1-37de-4a05-868d-31ba91e722a7",
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    }
  }
}
